# RAGnarok — Environment Configuration
# Copy this file to .env and adjust the values for your setup.
# No external API keys are required — everything runs locally via Ollama.

# URL of your local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model used for chat, HyDE query expansion, and reranking
LLM_MODEL=llama3

# Ollama model used for text embeddings
EMBEDDING_MODEL=nomic-embed-text

# Port the Python backend will listen on (default: 8000)
PORT=8000

# Port used by the Vite frontend dev server to reach the backend (default: 8000)
BACKEND_PORT=8000
